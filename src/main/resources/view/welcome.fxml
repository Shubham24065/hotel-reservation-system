<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>

<BorderPane prefHeight="680.0" prefWidth="900.0" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hotel.controller.WelcomeController">
    <top>
        <VBox>
            <HBox alignment="CENTER" prefHeight="78.0" styleClass="header-bar">
                <children>
                    <Label styleClass="header-title" text="Grand Stay Hotel" />
                </children>
            </HBox>
            <Separator />
        </VBox>
    </top>

    <center>
        <VBox alignment="TOP_CENTER" spacing="18.0" styleClass="content-panel">
            <padding>
                <Insets bottom="28.0" left="32.0" right="32.0" top="28.0" />
            </padding>
            <children>
                <Label styleClass="screen-title" text="Welcome to Grand Stay Hotel" />
                <Label styleClass="subtitle" text="Book your stay quickly and easily" />
                <Label styleClass="step-label" text="Step 1 of 7" />
                <StackPane prefHeight="210.0" prefWidth="560.0" styleClass="image-placeholder">
                    <children>
                        <Rectangle arcHeight="18.0" arcWidth="18.0" height="210.0" styleClass="placeholder-rect" width="560.0" />
                        <Label styleClass="placeholder-text" text="Grand Stay Hotel video / image" />
                    </children>
                </StackPane>
                <VBox alignment="CENTER" maxWidth="420.0" spacing="14.0">
                    <children>
                        <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleStartBooking" styleClass="primary-button" text="Start Booking" />
                        <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleFeedback" styleClass="primary-button" text="Feedback Form" />
                        <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleLogin" styleClass="primary-button" text="Admin Login" />
                        <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleRules" styleClass="secondary-button" text="Rules and Regulations" />
                    </children>
                </VBox>
            </children>
        </VBox>
    </center>

    <bottom>
        <VBox>
            <Separator />
            <HBox alignment="CENTER_LEFT" prefHeight="58.0" styleClass="footer-bar">
                <padding>
                    <Insets left="18.0" right="18.0" />
                </padding>
                <children>
                    <Label fx:id="footerDateTimeLabel" styleClass="footer-text" text="Loading date and time..." />
                </children>
            </HBox>
        </VBox>
    </bottom>
</BorderPane>
