<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="650.0" prefWidth="900.0" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hotel.controller.FeedbackController">
    <top>
        <VBox>
            <HBox alignment="CENTER_RIGHT" prefHeight="78.0" styleClass="header-bar">
                <padding><Insets left="18.0" right="18.0" /></padding>
                <children>
                    <Region HBox.hgrow="ALWAYS" />
                    <Label styleClass="header-title" text="Grand Stay Hotel" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button mnemonicParsing="false" onAction="#handleExit" styleClass="dark-button" text="Exit" />
                </children>
            </HBox>
            <Separator />
        </VBox>
    </top>

    <center>
        <VBox alignment="TOP_CENTER" spacing="18.0" styleClass="content-panel">
            <padding><Insets bottom="20.0" left="24.0" right="24.0" top="20.0" /></padding>
            <children>
                <Label styleClass="screen-title" text="Guest Feedback Form" />
                <Label styleClass="subtitle" text="Available only after full checkout" />
                <GridPane hgap="14.0" vgap="16.0" maxWidth="760.0" styleClass="form-card">
                    <padding><Insets bottom="22.0" left="22.0" right="22.0" top="22.0" /></padding>
                    <children>
                        <Label text="Reservation ID *" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                        <TextField fx:id="reservationIdField" promptText="e.g. RSV-202604031200-ABCD" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                        <Label text="Overall Rating (1-5) *" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                        <TextField fx:id="overallRatingField" promptText="Enter rating from 1 to 5" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                        <Label text="Additional Comments" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                        <TextArea fx:id="additionalCommentsArea" prefColumnCount="28" prefRowCount="6" promptText="Write your comments here..." GridPane.columnIndex="1" GridPane.rowIndex="2" />
                    </children>
                </GridPane>
                <HBox alignment="CENTER" spacing="18.0">
                    <children>
                        <Button mnemonicParsing="false" onAction="#handleClearForm" styleClass="secondary-button" text="Clear Form" />
                        <Button mnemonicParsing="false" onAction="#handleSubmitFeedback" styleClass="primary-button" text="Submit Feedback" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>

    <bottom>
        <VBox>
            <Separator />
            <HBox alignment="CENTER_LEFT" prefHeight="58.0" styleClass="footer-bar">
                <padding><Insets left="18.0" right="18.0" /></padding>
                <children>
                    <Label fx:id="footerDateTimeLabel" styleClass="footer-text" text="Loading date and time..." />
                </children>
            </HBox>
        </VBox>
    </bottom>
</BorderPane>
