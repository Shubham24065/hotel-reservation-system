<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="680.0" prefWidth="950.0" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hotel.controller.RoomSelectionController">
    <top>
        <VBox>
            <HBox alignment="CENTER_RIGHT" prefHeight="78.0" styleClass="header-bar">
                <padding>
                    <Insets left="18.0" right="18.0" />
                </padding>
                <children>
                    <Region HBox.hgrow="ALWAYS" />
                    <Label styleClass="header-title" text="Grand Stay Hotel" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button mnemonicParsing="false" styleClass="dark-button" text="Log Out" />
                </children>
            </HBox>
            <Separator />
        </VBox>
    </top>

    <center>
        <VBox alignment="TOP_CENTER" spacing="18.0" styleClass="content-panel">
            <padding>
                <Insets bottom="26.0" left="28.0" right="28.0" top="26.0" />
            </padding>
            <children>
                <Label styleClass="screen-title" text="Room Selection" />
                <Label styleClass="subtitle" text="Step 5 of 7" />
                <Label styleClass="info-text" text="Choose your room plan based on occupancy rules and availability." wrapText="true" />
            <HBox maxWidth="920.0" spacing="20.0">
    <children>
        <VBox spacing="8.0" styleClass="summary-pill">
            <children>
                <Label styleClass="pill-title" text="Guests" />
                <Label fx:id="guestSummaryLabel" text="Adults: 0 | Children: 0" />
            </children>
        </VBox>
        <VBox spacing="8.0" styleClass="summary-pill">
            <children>
                <Label styleClass="pill-title" text="Dates" />
                <Label fx:id="dateSummaryLabel" text="Check-in - Check-out" />
            </children>
        </VBox>
    </children>
</HBox>
                <TableView fx:id="roomTable" maxWidth="920.0" prefHeight="320.0" styleClass="table-card">
                    <columns>
                        <TableColumn fx:id="roomTypeColumn" prefWidth="300.0" text="Room Type" />
                        <TableColumn fx:id="capacityColumn" prefWidth="220.0" text="Capacity" />
                        <TableColumn fx:id="priceColumn" prefWidth="300.0" text="Price / Night" />
                    </columns>
                </TableView>

                <HBox alignment="CENTER" spacing="18.0">
                    <children>
                        <Button mnemonicParsing="false" onAction="#handleBack" styleClass="secondary-button" text="Back" />
                        <Button mnemonicParsing="false" onAction="#handleReset" styleClass="secondary-button" text="Reset" />
                        <Button mnemonicParsing="false" onAction="#handleNext" styleClass="primary-button" text="Next" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>

    <bottom>
        <VBox>
            <Separator />
            <HBox alignment="CENTER_LEFT" prefHeight="58.0" styleClass="footer-bar">
                <padding>
                    <Insets left="18.0" right="18.0" />
                </padding>
                <children>
                    <Label fx:id="footerDateTimeLabel" styleClass="footer-text" text="Loading date and time..." />
                </children>
            </HBox>
        </VBox>
    </bottom>
</BorderPane>