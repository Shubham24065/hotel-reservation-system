<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="520.0" prefWidth="720.0" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hotel.controller.AdminLoginController">
    <top>
        <VBox>
            <HBox alignment="CENTER" prefHeight="78.0" styleClass="header-bar">
                <children>
                    <Label styleClass="header-title" text="Grand Stay Hotel" />
                </children>
            </HBox>
            <Separator />
        </VBox>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="18.0" styleClass="content-panel">
            <padding>
                <Insets top="30.0" right="30.0" bottom="30.0" left="30.0" />
            </padding>
            <children>
                <Label styleClass="screen-title" text="Admin Login" />
                <VBox maxWidth="360.0" spacing="14.0" styleClass="form-card">
                    <padding>
                        <Insets top="24.0" right="24.0" bottom="24.0" left="24.0" />
                    </padding>
                    <children>
                        <Label text="Username" />
                        <TextField fx:id="usernameField" promptText="admin or manager" />
                        <Label text="Password" />
                        <PasswordField fx:id="passwordField" promptText="Enter password" />
                        <Label styleClass="inline-hint" text="Demo users: admin/admin123 or manager/manager123" wrapText="true" />
                    </children>
                </VBox>
                <HBox alignment="CENTER" spacing="18.0">
                    <children>
                        <Button mnemonicParsing="false" onAction="#handleBack" styleClass="secondary-button" text="Back" />
                        <Button mnemonicParsing="false" onAction="#handleLogin" styleClass="primary-button" text="Login" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>

    <bottom>
        <VBox>
            <Separator />
            <HBox alignment="CENTER_LEFT" prefHeight="58.0" styleClass="footer-bar">
                <padding>
                    <Insets left="18.0" right="18.0" />
                </padding>
                <children>
                    <Label fx:id="footerDateTimeLabel" styleClass="footer-text" text="Loading date and time..." />
                </children>
            </HBox>
        </VBox>
    </bottom>
</BorderPane>
