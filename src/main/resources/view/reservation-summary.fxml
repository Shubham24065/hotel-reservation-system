<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="600.0" prefWidth="950.0" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hotel.controller.ReservationSummaryController">
    <top>
        <VBox>
            <HBox alignment="CENTER_RIGHT" prefHeight="78.0" styleClass="header-bar">
                <padding>
                    <Insets left="18.0" right="18.0" />
                </padding>
                <children>
                    <Region HBox.hgrow="ALWAYS" />
                    <Label styleClass="header-title" text="Grand Stay Hotel" />
                    <Region HBox.hgrow="ALWAYS" />
                </children>
            </HBox>
            <Separator />
        </VBox>
    </top>

    <center>
        <VBox alignment="TOP_CENTER" spacing="18.0" styleClass="content-panel">
            <padding>
                <Insets top="28.0" right="28.0" bottom="28.0" left="28.0" />
            </padding>
            <children>
                <Label styleClass="screen-title" text="Reservation Summary" />
                <Label styleClass="subtitle" text="Step 7 of 7" />

                <HBox spacing="24.0" maxWidth="520.0" styleClass="form-card">
                    <children>
                        <VBox spacing="8.0" styleClass="form-card" HBox.hgrow="ALWAYS">
                            <padding>
                                <Insets top="20.0" right="20.0" bottom="20.0" left="20.0" />
                            </padding>
                            <children>
                                <Label styleClass="pill-title" text="Booking Details" />
                                <Label fx:id="bookingDetailsLabel" wrapText="true" text="Loading booking details..." />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <VBox spacing="10.0" maxWidth="520.0" styleClass="form-card">
                    <padding>
                        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0" />
                    </padding>
                    <children>
                        <Label styleClass="pill-title" text="Estimated Charges" />
                        <HBox><children><Label text="Subtotal" /><Region HBox.hgrow="ALWAYS" /><Label fx:id="subtotalLabel" text="\$0.00" /></children></HBox>
                        <HBox><children><Label text="Add-ons" /><Region HBox.hgrow="ALWAYS" /><Label fx:id="addonsLabel" text="\$0.00" /></children></HBox>
                        <HBox><children><Label text="Tax" /><Region HBox.hgrow="ALWAYS" /><Label fx:id="taxLabel" text="\$0.00" /></children></HBox>
                        <Separator />
                        <HBox><children><Label styleClass="grand-total" text="Estimated Total" /><Region HBox.hgrow="ALWAYS" /><Label fx:id="totalLabel" styleClass="grand-total" text="\$0.00" /></children></HBox>
                    </children>
                </VBox>

                <HBox alignment="CENTER" spacing="18.0">
                    <children>
                        <Button mnemonicParsing="false" onAction="#handleBack" styleClass="secondary-button" text="Back" />
                        <Button mnemonicParsing="false" onAction="#handleConfirmReservation" styleClass="primary-button" text="Confirm Reservation" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>

    <bottom>
        <VBox>
            <Separator />
            <HBox alignment="CENTER_LEFT" prefHeight="58.0" styleClass="footer-bar">
                <padding>
                    <Insets left="18.0" right="18.0" />
                </padding>
                <children>
                    <Label fx:id="footerDateTimeLabel" styleClass="footer-text" text="Loading date and time..." />
                </children>
            </HBox>
        </VBox>
    </bottom>
</BorderPane>
